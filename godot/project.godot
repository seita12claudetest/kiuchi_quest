config_version=5

[application]
config/name="木内の大冒険 DELUXE"
run/main_scene="res://main.tscn"
config/features=PackedStringArray("4.7")

[autoload]
GameState="*res://scripts/game_state.gd"

[display]
window/size/viewport_width=960
window/size/viewport_height=540
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="canvas_items"

[gui]
theme/custom_font="res://assets/fonts/NotoSansJP-Variable.ttf"

[rendering]
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/default_filters/use_nearest_mipmap_filter=false
textures/canvas_textures/default_texture_filter=0

[input]
move_left={"deadzone":0.3,"events":[Object(InputEventKey,"physical_keycode":65),Object(InputEventKey,"physical_keycode":4194319),Object(InputEventJoypadMotion,"axis":0,"axis_value":-1.0)]}
move_right={"deadzone":0.3,"events":[Object(InputEventKey,"physical_keycode":68),Object(InputEventKey,"physical_keycode":4194321),Object(InputEventJoypadMotion,"axis":0,"axis_value":1.0)]}
move_up={"deadzone":0.3,"events":[Object(InputEventKey,"physical_keycode":87),Object(InputEventKey,"physical_keycode":4194320),Object(InputEventJoypadMotion,"axis":1,"axis_value":-1.0)]}
move_down={"deadzone":0.3,"events":[Object(InputEventKey,"physical_keycode":83),Object(InputEventKey,"physical_keycode":4194322),Object(InputEventJoypadMotion,"axis":1,"axis_value":1.0)]}
interact={"deadzone":0.3,"events":[Object(InputEventKey,"physical_keycode":69),Object(InputEventKey,"physical_keycode":32),Object(InputEventKey,"physical_keycode":4194309),Object(InputEventJoypadButton,"button_index":0)]}
run={"deadzone":0.3,"events":[Object(InputEventKey,"physical_keycode":4194325),Object(InputEventJoypadButton,"button_index":2)]}

[layer_names]
