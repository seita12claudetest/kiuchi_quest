    "interactions":[
      {"id":"tanaka","position":[405,330],"label":"田中同僚","verb":"話す","time_cost":10,"repeat_policy":"once","effects":{"trust":1,"flags":["met_tanaka"]},"text":"田中「木内、今日の伝票はここだ。焦らなくていい。分からなければ、分からないと早めに言えよ」"},
      {"id":"sato","position":[555,295],"label":"佐藤先輩","verb":"話す","time_cost":15,"repeat_policy":"once","requires_flags":["met_tanaka"],"blocked_text":"佐藤先輩は資料を読んでいる。まず田中さんへ挨拶しよう。","effects":{"expertise":2,"flags":["received_first_job"]},"text":"佐藤「AS/400は便利だが、入力する元の数字までは直してくれない。まず商品コードを照合してみろ」"},
      {"id":"terminal","position":[770,165],"label":"5250端末","verb":"調べる","time_cost":30,"repeat_policy":"once","requires_flags":["received_first_job"],"blocked_text":"端末は空いているが、勝手に操作してはいけない。担当者の指示を待とう。","effects":{"energy":-5,"expertise":3,"performance":2,"flags":["checked_terminal"]},"text":"黒い画面に緑色の文字。旧コードと新コードの対応表に、一件だけ更新日の古い行がある。"},
      {"id":"sales_ledger","position":[365,230],"label":"月次売上台帳","verb":"照合する","time_cost":45,"repeat_policy":"once","requires_flags":["checked_terminal"],"blocked_text":"分厚い台帳だ。先に端末側の商品コードを確認した方がよさそうだ。","effects":{"energy":-8,"expertise":3,"trust":1,"performance":4,"flags":["checked_ledger"]},"text":"伝票を一枚ずつ照合すると、集計差額と同じ金額の商品が見つかった。偶然ではなさそうだ。"},
      {"id":"unprocessed_slips","position":[590,225],"label":"未処理伝票の束","verb":"整理する","action":"battle","requires_flags":["first_day_complete"],"blocked_text":"初日に任された確認を終えてから取り掛かろう。","text":"未処理伝票を前にすると、木内の意識が心象世界へ沈んでいく。"},
      {"id":"weekly_planner","position":[680,345],"label":"週間予定表","verb":"仕事を選ぶ","action":"work_plan","requires_flags":["first_day_reported"],"blocked_text":"まず初日に任された仕事を報告しよう。","text":"今日の仕事の配分を決める。"},
      {"id":"accounting_summary","position":[295,335],"label":"経理側集計表","verb":"確認する","time_cost":30,"repeat_policy":"once","requires_flags":["first_battle_won"],"blocked_text":"未処理伝票を整理して、比較できる状態にしよう。","effects":{"energy":-5,"expertise":2,"performance":3,"flags":["checked_accounting_summary"]},"text":"営業側より経理側の締めが一日早い。同じ商品でも、締め日により新旧二つのコードで計上されている。"},
      {"id":"migration_table","position":[835,250],"label":"商品コード移行表","verb":"照合する","time_cost":45,"repeat_policy":"once","requires_flags":["first_battle_won"],"blocked_text":"まず未処理伝票の発生元を切り分けよう。","effects":{"energy":-7,"expertise":4,"performance":4,"flags":["checked_migration_table"]},"text":"移行表の一行だけ、4月1日の更新対象から漏れている。AS/400そのものではなく、移行前に決めた運用の穴だ。"},
      {"id":"accounting_staff","position":[620,340],"label":"経理の山川さん","verb":"話す","time_cost":20,"repeat_policy":"once","requires_flags":["first_battle_won"],"blocked_text":"今は締め処理で手が離せないようだ。","effects":{"trust":1,"politics":1,"flags":["interviewed_accounting"]},"text":"山川「こちらは前日分を朝一番で締めます。営業さんが夕方に直したコードは、翌日まで来ないんです」"},
      {"id":"root_cause_report","position":[555,255],"label":"佐藤先輩への中間報告","verb":"報告する","time_cost":30,"repeat_policy":"once","requires_flags":["checked_accounting_summary","checked_migration_table","interviewed_accounting"],"blocked_text":"集計表・移行表・経理の締め手順。三方向の事実を揃えてから報告しよう。","effects":{"trust":1,"expertise":3,"performance":7,"flags":["root_cause_found"]},"text":"佐藤「機械の故障じゃない。更新漏れと部署ごとの締め時刻の差だ。そこまで分けて話せれば、直し方を選べる」"},
      {"id":"case_strategy","position":[735,335],"label":"案件作戦会議","verb":"参加する","time_cost":45,"repeat_policy":"once","requires_flags":["root_cause_found"],"blocked_text":"原因の証拠を揃え、佐藤先輩へ中間報告しよう。","effects":{"energy":-5,"trust":1,"politics":2,"performance":5,"flags":["case_ready"]},"text":"田中は顧客への影響を、佐藤は移行表の修正を優先した。木内は双方を工程表に並べ、同時に進められる順序を提案した。"},
      {"id":"monthly_case","position":[470,275],"label":"月次売上集計の不一致","verb":"案件を解決する","action":"battle","battle_mode":"case","requires_flags":["case_ready"],"blocked_text":"原因を特定し、関係者と作戦をまとめてから臨もう。","text":"営業・経理・電算の四人が資料を持ち寄る。問題を誰かのせいにせず、締め処理までに解決する。"},
